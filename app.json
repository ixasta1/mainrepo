{
  "name": "ASTA_YT MUSIC BOT",
  "description": "A Telegram Music Player Bot, written in Python with Pyrogram and Py-TgCalls.",
  "logo": "https://files.catbox.moe/fdkxi4.jpg",
  "keywords": [
    "python3",
    "telegram",
    "bot",
    "ASTA_YT",
    "MusicBot",
    "telegram-bot",
    "pyrogram"
  ],
  "env": {
    "API_ID": {
      "description": "Get this value from https://my.telegram.org",
      "value": "",
      "required": true
    },
    "API_HASH": {
      "description": "Get this value from https://my.telegram.org",
      "value": "",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "A Bot Token from BotFather.",
      "value": "",
      "required": true
    },
    "MONGO_DB_URI": {
      "description": "Get a MongoDB URI from MongoDB Atlas.",
      "value": "",
      "required": true
    },
    "OWNER_ID": {
      "description": "Telegram User ID of the bot owner.",
      "value": "",
      "required": true
    },
    "STRING_SESSION": {
      "description": "Pyrogram v2 String Session.",
      "value": "",
      "required": true
    },
    "HEROKU_API_KEY": {
      "description": "Your Heroku API Key.",
      "value": "",
      "required": false
    },
    "HEROKU_APP_NAME": {
      "description": "Your Heroku App Name.",
      "value": "",
      "required": false
    },
    "LOGGER_ID": {
      "description": "Telegram Log Group ID.",
      "value": "",
      "required": true
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    },
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest.git"
    }
  ],
  "stack": "container"
}
